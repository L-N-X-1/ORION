{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuraKPI",
  "type": "object",
  "required": ["cell_id", "ts", "prb_util", "throughput_mbps", "sinr_db", "latency_p95_ms"],
  "properties": {
    "cell_id":          { "type": "string" },
    "ts":               { "type": "string", "format": "date-time" },
    "sim_time_s":       { "type": "number" },
    "prb_util":         { "type": "number", "minimum": 0, "maximum": 100 },
    "throughput_mbps":  { "type": "number" },
    "sinr_db":          { "type": "number" },
    "cqi":              { "type": "integer", "minimum": 0, "maximum": 15 },
    "latency_p95_ms":   { "type": "number" },
    "packet_loss_pct":  { "type": "number" },
    "cpu_load_pct":     { "type": "number" },
    "ho_fail_rate":     { "type": "number" },
    "energy_mode":      { "type": "string", "enum": ["ACTIVE","SLEEP","SHUTDOWN"] },
    "sla_violation":    { "type": "boolean" },
    "is_peak":          { "type": "boolean" }
  }
}
